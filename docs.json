{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Neural4D API Docs",
  "description": "Neural4D legacy management API docs with localized old-version references and reserved spaces for v1 and v2.",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "system",
    "strict": false
  },
  "background": {
    "decoration": "gradient"
  },
  "navigation": {
    "languages": [
      {
        "language": "zh",
        "default": true,
        "versions": [
          {
            "version": "old",
            "default": true,
            "groups": [
              {
                "group": "开始使用",
                "pages": [
                  "zh/index",
                  "zh/quickstart"
                ]
              },
              {
                "group": "API 参考",
                "openapi": {
                  "source": "openapi.zh.json",
                  "directory": "zh-old-api-reference"
                }
              }
            ]
          },
          {
            "version": "v1",
            "groups": [
              {
                "group": "开始使用",
                "pages": [
                  "zh/index",
                  "zh/quickstart"
                ]
              },
              {
                "group": "API 参考",
                "pages": [
                  "zh/v1-coming-soon"
                ]
              }
            ]
          },
          {
            "version": "v2",
            "groups": [
              {
                "group": "开始使用",
                "pages": [
                  "zh/index",
                  "zh/quickstart"
                ]
              },
              {
                "group": "API 参考",
                "pages": [
                  "zh/v2-coming-soon"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "en",
        "versions": [
          {
            "version": "old",
            "default": true,
            "groups": [
              {
                "group": "Get started",
                "pages": [
                  "en/index",
                  "en/quickstart"
                ]
              },
              {
                "group": "API reference",
                "openapi": {
                  "source": "openapi.json",
                  "directory": "en-old-api-reference"
                }
              }
            ]
          },
          {
            "version": "v1",
            "groups": [
              {
                "group": "Get started",
                "pages": [
                  "en/index",
                  "en/quickstart"
                ]
              },
              {
                "group": "API reference",
                "pages": [
                  "en/v1-coming-soon"
                ]
              }
            ]
          },
          {
            "version": "v2",
            "groups": [
              {
                "group": "Get started",
                "pages": [
                  "en/index",
                  "en/quickstart"
                ]
              },
              {
                "group": "API reference",
                "pages": [
                  "en/v2-coming-soon"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true,
      "credentials": false
    },
    "examples": {
      "languages": [
        "curl",
        "javascript",
        "python"
      ],
      "defaults": "all",
      "autogenerate": true
    }
  },
  "contextual": {
    "display": "header",
    "options": [
      "copy",
      "view",
      "download-spec",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  }
}
